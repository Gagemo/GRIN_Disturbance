######################### Clears Environment & History  ########################
rm(list=ls(all=TRUE))
cat("\014")
#########################     Installs Packages   ##############################
list.of.packages <- c("tidyverse", "vegan", "agricolae", "extrafont", "ggrepel",
"ggsignif", "multcompView", "ggpubr", "rstatix",'rmarkdown',
"labdsv", "pairwiseAdonis", "devtools", "knitr",
"tables", "openxlsx")
