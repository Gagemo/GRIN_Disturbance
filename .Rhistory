# Test for Significance #
Fun_anova = aov(Coverage ~ Treatment + Group, data = GRIN)
summary(Fun_anova)
tukey.one.way<-TukeyHSD(Fun_anova)
tukey.one.way
HSD.stat = HSD.test(Fun_anova,trt = c("Treatment", "Group")) #HSD Tukey
HSD.stat
