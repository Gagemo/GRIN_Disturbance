library(ggplot2)
library(tidyverse)
library(ggpubr)
library (ggbeeswarm)
library(forcats)
setwd("~/Work/Plant Nursery/Pinus Serotina/R Code")
# import data
ACF <- read.csv("Data/Planting Data_ACF.csv")
mudswamp <- read.csv("Data/Planting Data_Mudswamp.csv")
# clean data
ACF_clean <- ACF %>% select(c(1,2,4,5,8:10))
ACF_clean <- ACF_clean %>% mutate(Delta_Hgt_in = Final_Hgt_in - Init_Hgt_in, .before=Status)
ACF_clean <- ACF_clean %>% mutate(NormInit = (Init_Hgt_in - mean(Init_Hgt_in))) #normalizing initial height
# fixing the levels for community
ACF_clean$Community <- fct(ACF_clean$Community, levels = c("CD", "HF", "NHF", "MF"))
levels(ACF_clean$Community)
ACF_table <- table(ACF_clean$Community, ACF_clean$Status)
ACF_table
