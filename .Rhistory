matrify()
# Select 2022 Treatment Data matrix #
Spp_22 <- dplyr::select(GRIN_22, ID_, Species, Coverage) %>%
matrify()
Treat = ungroup(GRIN_21) %>%
dplyr::select(ID_, Treatment) %>%
group_by(Treatment, ID_) %>%
summarise() %>%
remove_rownames() %>%
column_to_rownames(var = 'ID_')
