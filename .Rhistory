library(ggplot2)
library(reshape2)
library(gridExtra)
library(tidyverse)
library(vegan)
library(grid)
library(labdsv)
set.seed(2)
DOGfennel_Community = read.csv("ACMF_DOGFenPlots(2017,2018)  - Community Data.csv") %>%
filter(Plot.Level != ".") %>% # Indicates a plot.level with no species found
filter(Species != ".") # "." Indicates species that were not found post-treatment but found in plots pretreatment
DOGfennel_Community$Map.Plot. = as.factor(DOGfennel_Community$Map.Plot) # Makes plot numbers appear as factors instead of continous
