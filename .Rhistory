bar
# compact letter display
cld <- multcompLetters4(anova, tukey.one.way)
#
data_summary <- function(data, varname, groupnames){
require(plyr)
summary_func <- function(x, col){
c(mean = mean(x[[col]], na.rm=TRUE),
sd = sd(x[[col]], na.rm=TRUE))
}
data_sum<-ddply(data, groupnames, .fun=summary_func,
varname)
data_sum <- rename(data_sum, c("mean" = varname))
return(data_sum)
}
bare1 <- data_summary(bare, varname="Coverage",
groupnames=c("Treatment", "Year"))
# Label Years for ggplot #
year_names <- as_labeller(
c(`1` = "2021", `2` = "2022"))
## Bareground Coverage ##
bar =
ggplot(bare1, aes(x = Treatment, y = Coverage, fill = Treatment)) +
geom_bar(stat = "identity", alpha = 0.6) +
geom_errorbar(aes(ymin=Coverage-sd, ymax=Coverage+sd), width=.2,
position=position_dodge(.9)) +
geom_text(aes(label = cld)) +
facet_wrap(.~Year, labeller = year_names) +
scale_fill_manual(values=c("#FF3399", "#FFFF00", "#3366FF")) +
geom_signif(y_position = c(50,45), xmin = c(0.7,2), xmax = c(1.9,3),
annotation=c("a", "b"),
size = 0.8, textsize = 5, tip_length = .01) +
theme_classic() +
theme(panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
panel.border = element_blank(),
panel.background = element_blank(),
plot.title = element_text(hjust = 0.5, color="black",
size=20, face="bold"),
axis.title.x = element_text(size=20, face="bold", colour = "black"),
axis.title.y = element_text(size=20, face="bold", colour = "black",
vjust=2),
axis.text.x=element_text(size=20, face = "bold", color = "black"),
axis.text.y=element_text(size=20, face = "bold", color = "black"),
legend.text=element_text(size=20, face = "bold", color = "black"),
legend.title=element_text(size=20, face = "bold", color = "black"),
legend.position="NA",strip.text.x =
element_text(size = 20, colour = "black", face = "bold")) +
guides(fill = guide_legend(label.position = "bottom")) +
labs(x = "", y = "Bare Ground % Coverage")
bar
list.of.packages <- c("tidyverse", "vegan", "agricolae", "multcompLetters4")
new.packages <- list.of.packages[!(list.of.packages %in%
installed.packages()[,"Package"])]
if(length(new.packages)) install.packages(new.packages)
library(tidyverse)
library(multcompLetters4)
library(tidyverse)
library(vegan)
library(agricolae)
library(multcompLetters4)
GRIN = read.csv("Data/GRIN - 2021-2023.csv")
GRIN$Coverage = as.numeric(GRIN$Coverage)
GRIN$Plot = as.character(GRIN$Plot)
str(GRIN)
summary(GRIN)
# Remove Seeding Treatment #
GRIN = filter(GRIN, Treatment != 'S')
# Remove Year Three #
GRIN = filter(GRIN, Year != 3)
# Reclasifys coverage data (CV) from 1-10 scale to percent scale #
GRIN <- mutate(GRIN, Coverage = case_when(
grepl(0, Coverage) ~ 0,
grepl(1, Coverage) ~ 0.1,
grepl(2, Coverage) ~ 0.5,
grepl(3, Coverage) ~ 1.5,
grepl(4, Coverage) ~ 3.5,
grepl(5, Coverage) ~ 7.5,
grepl(6, Coverage) ~ 17.5,
grepl(7, Coverage) ~ 37.5,
grepl(8, Coverage) ~ 62.5,
grepl(9, Coverage) ~ 85,
grepl(10, Coverage) ~ 97.5
))
# Filters data for just bareground #
bare = filter(GRIN, Group == "Bare")
# Creates data sets by year #
bare_21 = filter(bare, Year == 1)
bare_22 = filter(bare, Year == 2)
# Test for Significance across years#
anova = aov(Coverage ~ Treatment, data = bare_21)
summary(anova)
tukey.one.way<-TukeyHSD(anova)
tukey.one.way
anova = aov(Coverage ~ Treatment, data = bare_22)
summary(anova)
tukey.one.way<-TukeyHSD(anova)
tukey.one.way
# compact letter display
cld <- multcompLetters4(anova, tukey.one.way)
#  Create function that creates error bars for barplot #
data_summary <- function(data, varname, groupnames){
require(plyr)
summary_func <- function(x, col){
c(mean = mean(x[[col]], na.rm=TRUE),
sd = sd(x[[col]], na.rm=TRUE))
}
data_sum<-ddply(data, groupnames, .fun=summary_func,
varname)
data_sum <- rename(data_sum, c("mean" = varname))
return(data_sum)
}
# Creates file for significance letters for barplot #
cld <- multcompLetters4(anova, tukey.one.way)
#  Create function that creates error bars for barplot #
data_summary <- function(data, varname, groupnames){
require(plyr)
summary_func <- function(x, col){
c(mean = mean(x[[col]], na.rm=TRUE),
sd = sd(x[[col]], na.rm=TRUE))
}
data_sum<-ddply(data, groupnames, .fun=summary_func,
varname)
data_sum <- rename(data_sum, c("mean" = varname))
return(data_sum)
}
bare1 <- data_summary(bare, varname="Coverage",
groupnames=c("Treatment", "Year"))
# Label Years for ggplot #
year_names <- as_labeller(
c(`1` = "2021", `2` = "2022"))
## Bareground Coverage ##
bar =
ggplot(bare1, aes(x = Treatment, y = Coverage, fill = Treatment)) +
geom_bar(stat = "identity", alpha = 0.6) +
geom_errorbar(aes(ymin=Coverage-sd, ymax=Coverage+sd), width=.2,
position=position_dodge(.9)) +
geom_text(aes(label = cld)) +
facet_wrap(.~Year, labeller = year_names) +
scale_fill_manual(values=c("#FF3399", "#FFFF00", "#3366FF")) +
geom_signif(y_position = c(50,45), xmin = c(0.7,2), xmax = c(1.9,3),
annotation=c("a", "b"),
size = 0.8, textsize = 5, tip_length = .01) +
theme_classic() +
theme(panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
panel.border = element_blank(),
panel.background = element_blank(),
plot.title = element_text(hjust = 0.5, color="black",
size=20, face="bold"),
axis.title.x = element_text(size=20, face="bold", colour = "black"),
axis.title.y = element_text(size=20, face="bold", colour = "black",
vjust=2),
axis.text.x=element_text(size=20, face = "bold", color = "black"),
axis.text.y=element_text(size=20, face = "bold", color = "black"),
legend.text=element_text(size=20, face = "bold", color = "black"),
legend.title=element_text(size=20, face = "bold", color = "black"),
legend.position="NA",strip.text.x =
element_text(size = 20, colour = "black", face = "bold")) +
guides(fill = guide_legend(label.position = "bottom")) +
labs(x = "", y = "Bare Ground % Coverage")
bar
View(bare)
# table with factors and 3rd quantile
dt <- group_by(bare, Coverage) %>%
summarise(w=mean(Coverage), sd = sd(Coverage)) %>%
arrange(desc(w))
# extracting the compact letter display and adding to the Tk table
cld <- as.data.frame.list(cld$Treatment)
dt$cld <- cld$Letters
View(dt)
# table with factors and 3rd quantile
dt <- group_by(bare, Treatment) %>%
summarise(w=mean(Coverage), sd = sd(Coverage)) %>%
arrange(desc(w))
# extracting the compact letter display and adding to the Tk table
cld <- as.data.frame.list(cld$Treatment)
dt$cld <- cld$Letters
