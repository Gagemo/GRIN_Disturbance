Fire =
ggplot() +
geom_point(data = NMDS, aes(x = MDS.MDS1, y = MDS.MDS2, color = Fire, shape = Treat_Pre.Treatment_Year)) +
stat_ellipse(data = NMDS, aes(x = MDS.MDS1, y = MDS.MDS2, color = Fire), linetype = "dashed", show.legend = T) +
stat_ellipse(data = NMDS, aes(x = MDS.MDS1, y = MDS.MDS2, color = Fire), show.legend = T) +
theme_bw() +
labs(x="MDS1", y="MDS2", title = "Fire Pre & Post-treatment", color = "Fire Treatment", shape = "Pre or Post-treatment") +
theme(plot.title = element_text(hjust = 0.5))
